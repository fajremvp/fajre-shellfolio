---
// src/components/FastfetchHero.astro
import AsciiFace from './AsciiFace.astro';
---
<section class="fastfetch-container">
  <div class="ascii-column">
    <AsciiFace />
  </div>
  <div class="info-column">
    <h1><span class="user">fajre</span><span class="at">@</span><span class="host">nixos</span></h1>
    <div class="separator">-------------------</div>
    <p><span class="label">OS:</span> NixOS</p>
    <p><span class="label">WM:</span> Niri</p>
    <p><span class="label">Terminal:</span> Kitty</p>
    <p><span class="label">Editor:</span> Neovim</p>
    <p><span class="label">Focus:</span> Privacy / OSS / Linux</p>

    <div class="colors">
      <span class="color-block c1"></span><span class="color-block c2"></span>
      <span class="color-block c3"></span><span class="color-block c4"></span>
      <span class="color-block c5"></span><span class="color-block c6"></span>
    </div>
  </div>
</section>

<style>
  .fastfetch-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    font-family: var(--font-tui);
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .fastfetch-container {
      grid-template-columns: auto 1fr;
      align-items: center;
    }
  }

  .user, .host { color: var(--accent-green); font-weight: bold; font-size: 1.2rem; }
  .at { color: var(--text-main); font-size: 1.2rem; }
  .separator { color: var(--text-muted); margin: 0.5rem 0; letter-spacing: -1px; }
  .label { color: var(--accent-green); font-weight: bold; margin-right: 0.5rem; }
  p { margin: 0.3rem 0; }

  .colors { margin-top: 1rem; display: flex; gap: 6px; }
  .color-block { width: 18px; height: 18px; display: inline-block; border-radius: 2px; }
  /* Cores estilo Catppuccin para os bloquinhos */
  .c1 { background: #45475a; } .c2 { background: #f38ba8; } .c3 { background: #a6e3a1; }
  .c4 { background: #f9e2af; } .c5 { background: #89b4fa; } .c6 { background: #cba6f7; }
</style>
