---
// src/components/BootLoader.astro
---
<div id="boot-loader" class="fixed-fullscreen">
  <pre class="tui-text">
    <span class="green">[ OK ]</span> Loading NixOS environment...
    <span class="green">[ OK ]</span> Starting portfolio service...
  </pre>
</div>

<script is:inline>
  // Script inline roda ANTES do CSS pintar a tela (evita FOUC)
  if (sessionStorage.getItem('portfolioBooted')) {
    document.documentElement.classList.add('skip-loader');
  } else {
    sessionStorage.setItem('portfolioBooted', 'true');
    // Lógica para remover o loader após X segundos
    setTimeout(() => {
      document.getElementById('boot-loader').style.display = 'none';
    }, 1500); // 1.5s cravado
  }
</script>

<style>
  .fixed-fullscreen {
    position: fixed; inset: 0; background: var(--bg-crust); z-index: 9999;
    display: flex; flex-direction: column; padding: 2rem;
  }
  .tui-text { font-family: var(--font-tui); color: var(--text-muted); }
  .green { color: var(--accent-green); }
</style>
